    {
      "id": "xRtnBAS5Y9GTkneNSvnEn",
      "type": "text",
      "x": 1798.6487211669382,
      "y": 2839.6531553169425,
      "width": 721.363525390625,
      "height": 70,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ab",
      "roundness": null,
      "seed": 1335061734,
      "version": 36,
      "versionNonce": 865071142,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783648703686,
      "link": null,
      "locked": false,
      "text": "SC-001        El sistema puede implementarse en distintas\nherramientas sin cambiar su arquitectura.",
      "fontSize": 28,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SC-001        El sistema puede implementarse en distintas herramientas sin cambiar su arquitectura.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "lrtzeqlqexnyrTWbgYCqf",
      "type": "text",
      "x": 1798.6487211669382,
      "y": 2978.298424607221,
      "width": 796.0674438476562,
      "height": 70,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
