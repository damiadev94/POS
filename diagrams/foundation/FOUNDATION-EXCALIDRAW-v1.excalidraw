    {
      "id": "5lbHGWewLkdXdqHGq4teo",
      "type": "text",
      "x": -91.23281409800234,
      "y": 2121.27330843358,
      "width": 401.07177734375,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
